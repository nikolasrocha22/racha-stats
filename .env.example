# URL do seu projeto Supabase (obtenha em Settings -> API)
VITE_SUPABASE_URL=https://seu-projeto.supabase.co

# Chave pública anon do seu Supabase (obtenha em Settings -> API)
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# E-mail do Administrador (só esta conta poderá gerenciar as Configurações e API keys)
VITE_ADMIN_EMAIL=nikolas@example.com
