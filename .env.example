# ── Supabase (client-side, prefixo VITE_ obrigatório) ──
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ── Admin ──
VITE_ADMIN_EMAIL=seu-email@exemplo.com

# ── NVIDIA AI (server-side only, SEM prefixo VITE_) ──
# Usada pela serverless function em /api/ai
# Obtenha em: https://build.nvidia.com/
NVIDIA_API_KEY=nvapi-sua-chave-aqui
